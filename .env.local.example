# ───────── 本機開發(co-car local Supabase,port +10 避開 dinbando) ─────────
# 值來自 `supabase status -o env`(本機自簽,非雲端申請)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status 的 anon key (eyJ...)>

# 後端 / Server Action 用(繞過 RLS,僅 server 端,切勿放進前端 bundle)
SUPABASE_SERVICE_ROLE_KEY=<supabase status 的 service_role key (eyJ...)>

# 工號 → email 網域
NEXT_PUBLIC_INTERNAL_EMAIL_DOMAIN=test.local

# ───────── 雲端 (.env.production.local,由部署流程產生,勿進 repo) ─────────
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<legacy anon JWT>
# SUPABASE_SERVICE_ROLE_KEY=<legacy service_role JWT>
